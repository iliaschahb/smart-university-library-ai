# =========================
# Flask configuration
# =========================
SECRET_KEY=change-me
FLASK_ENV=development
PORT=5000

# =========================
# Database configuration
# =========================
# SQLite pour la démonstration académique
DATABASE_URL=sqlite:///library.db

# PostgreSQL pour une version production future
# DATABASE_URL=postgresql://user:password@localhost:5432/library_ai

# =========================
# Demo accounts
# Ne jamais mettre les vrais mots de passe dans un dépôt public
# =========================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

LIBRARIAN_USERNAME=biblio
LIBRARIAN_PASSWORD=change-me

# =========================
# Cookies / Sessions
# true pour Codespaces HTTPS
# false pour localhost simple si nécessaire
# =========================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None
PERMANENT_SESSION_LIFETIME_HOURS=8
